# ============================================================
# AI Provider Configuration (optional - only needed for AI mode)
# ============================================================

# Force a specific provider: gemini | openai | anthropic | ollama
# If not set, auto-detection tries providers in order below
# SKILL_AI_PROVIDER=gemini

# Gemini - Free tier available at https://aistudio.google.com/apikey
# GEMINI_API_KEY=your-key-here

# OpenAI - https://platform.openai.com/api-keys
# OPENAI_API_KEY=your-key-here
# OPENAI_BASE_URL=https://your-azure-endpoint.openai.azure.com  # Optional: Azure OpenAI
# OPENAI_MODEL=gpt-4o-mini  # Optional: override model

# Anthropic - https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=your-key-here

# Ollama (local, free) - https://ollama.ai
# No API key needed. Install and run: ollama pull llama3.2
# Opt-in: set OLLAMA_BASE_URL (or SKILL_AI_PROVIDER=ollama) to enable auto-detection
# OLLAMA_MODEL=llama3.2
# OLLAMA_BASE_URL=http://localhost:11434

# ============================================================
# Skill Activation Settings
# ============================================================

# Conservativeness level: strict | balanced | aggressive
# Controls how aggressively skills are suggested
# SKILL_CONSERVATIVENESS=balanced

# Debug mode - show classification details in stderr
# DEBUG_SKILLS=0

# ============================================================
# PreToolUse Guard Settings
# ============================================================

# Enable soft-blocking (block first edit, allow after)
# Default: false (suggest only, don't block)
# PRETOOLUSE_SOFT_BLOCK=false

# Skip mandatory skill enforcement entirely
# SKIP_MANDATORY_SKILLS=false

# Skip AI analysis in PreToolUse guard
# SKIP_PRETOOLUSE_AI=false

# Enable detailed guard debug logging
# SKILL_GUARD_DEBUG=false

# ============================================================
# Session Intelligence Settings
# ============================================================

# Enable dev-doc update reminders (injected into Claude's context)
# SESSION_DOCS_ENABLED=true

# Enable vector search over dev docs (requires GEMINI_API_KEY + indexed DB)
# SESSION_SEARCH_ENABLED=true

# Vector search quality tier: fast | moderate | quality
# fast: 1 embed → search (lowest latency)
# moderate: embed → search → Gemini assessment
# quality: embed + search terms (parallel) → multi-query → assessment
# SESSION_SEARCH_QUALITY=quality

# Stderr verbosity for session intelligence output
# 0 = silent, 1 = one-line summary, 2 = detailed multi-line (default)
# SESSION_INTEL_VERBOSE=2

# Prompts between dev-doc update reminders
# DOC_UPDATE_TURNS=2

# Debug logging for session doc worker
# DEBUG_SESSION_INTEL=0
