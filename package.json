{
  "name": "skogharness",
  "version": "4.0.0",
  "description": "Declarative agent config for Claude Code and Codex: a skogai.json manifest for skills, MCP servers, and stack profiles, synced to each agent's native config, plus hand-maintained skills.",
  "type": "module",
  "main": "src/index.js",
  "bin": {
    "skogharness": "bin/cli.js",
    "harness": "bin/cli.js"
  },
  "files": [
    "bin/",
    "src/",
    "templates/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "install:global": "./scripts/install-global.sh",
    "test": "node --test",
    "test:security": "node --test test/*.test.js",
    "lint": "eslint src/ test/ bin/ templates/.claude/utils/",
    "prepublishOnly": "bun run lint && bun test"
  },
  "keywords": [
    "claude",
    "claude-code",
    "codex",
    "agents",
    "claude-skills",
    "hci",
    "usability",
    "apple-hig",
    "hig-doctor",
    "human-interface-guidelines",
    "design-audit",
    "copywriting",
    "marketing",
    "mcp",
    "toon",
    "token-efficiency",
    "starter"
  ],
  "author": "skogai",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/skogai/harness.git"
  },
  "bugs": {
    "url": "https://github.com/skogai/harness/issues"
  },
  "homepage": "https://github.com/skogai/harness",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "chalk": "5.6.2",
    "commander": "15.0.0",
    "fs-extra": "11.3.3",
    "inquirer": "14.0.2",
    "ora": "9.4.0"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@toon-format/toon": "2.1.0",
    "eslint": "10.4.1",
    "gpt-tokenizer": "3.0.0"
  },
  "packageManager": "bun@1.3.11"
}
