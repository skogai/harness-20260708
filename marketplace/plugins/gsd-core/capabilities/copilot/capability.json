{
  "id": "copilot",
  "role": "runtime",
  "version": "1.7.0-rc.6",
  "title": "GitHub Copilot",
  "description": "GitHub Copilot (VS Code) — markdown config format; copilot-inline hook surface; no hook events emitted; flat skill nesting (unconfirmed recursive loader); tier-2 support.",
  "tier": "core",
  "requires": [],
  "engines": {
    "gsd": ">=1.6.0"
  },
  "runtime": {
    "configHome": {
      "kind": "dot-home",
      "name": ".copilot",
      "env": [
        "COPILOT_CONFIG_DIR",
        "COPILOT_HOME"
      ]
    },
    "localConfigDir": ".github",
    "configFormat": "markdown",
    "artifactLayout": {
      "global": [
        {
          "kind": "skills",
          "destSubpath": "skills",
          "prefix": "gsd-",
          "nesting": "flat",
          "recursive": false,
          "converter": "convertClaudeCommandToCopilotSkill"
        },
        {
          "kind": "agents",
          "destSubpath": "agents",
          "prefix": "gsd-",
          "nesting": "flat",
          "recursive": false,
          "converter": "convertClaudeAgentToCopilotAgent"
        }
      ],
      "local": [
        {
          "kind": "skills",
          "destSubpath": "skills",
          "prefix": "gsd-",
          "nesting": "flat",
          "recursive": false,
          "converter": "convertClaudeCommandToCopilotSkill"
        },
        {
          "kind": "agents",
          "destSubpath": "agents",
          "prefix": "gsd-",
          "nesting": "flat",
          "recursive": false,
          "converter": "convertClaudeAgentToCopilotAgent"
        }
      ]
    },
    "commandStyle": "slash-hyphen",
    "hooksSurface": "copilot-inline",
    "sandboxTier": "none",
    "supportTier": 2,
    "installSurface": "copilot-instructions",
    "writesSharedSettings": false,
    "permissionWriter": null,
    "extendedHookEvents": [],
    "hostIntegration": {
      "embeddingMode": "declarative",
      "commandSurface": "slash-file",
      "dispatch": {
        "namedDispatch": true,
        "nested": false,
        "maxDepth": 1,
        "background": true,
        "subagentToolkit": "full",
        "backgroundDispatch": false
      },
      "modelMode": "passive",
      "hookBus": "host",
      "stateIO": "filesystem",
      "transport": "mcp",
      "runtime": "undocumented"
    },
    "hostBehaviors": {
      "reapplyCommand": "/gsd-update --reapply",
      "agentFileExtension": ".agent.md",
      "skipSharedHooksInstall": true,
      "noPathRewrite": true
    }
  }
}
