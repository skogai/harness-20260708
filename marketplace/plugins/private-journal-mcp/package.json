{
  "name": "private-journal-mcp",
  "version": "2.0.1",
  "description": "A lightweight MCP server that provides Claude with a private journaling and reflection capability",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "private-journal-mcp": "./dist/index.js"
  },
  "scripts": {
    "prepare": "npm run build",
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts"
  },
  "keywords": [
    "mcp",
    "journal",
    "private",
    "claude",
    "ai"
  ],
  "author": "Jesse Vincent <jesse@fsck.com>",
  "license": "MIT",
  "devDependencies": {
    "@types/jest": "^29.0.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "jest": "^29.0.0",
    "prettier": "^3.0.0",
    "ts-jest": "^29.0.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@xenova/transformers": "^2.0.1"
  },
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE"
  ],
  "allowScripts": {
    "protobufjs@7.6.5": true
  }
}
